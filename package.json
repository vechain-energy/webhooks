{
  "name": "vechain.webhooks",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted VeChain webhook processor configured with YAML and launched with Docker Compose.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "validate": "tsx src/cli/index.ts validate",
    "dry-run": "tsx src/cli/index.ts dry-run",
    "print-rules": "tsx src/cli/index.ts print-rules"
  },
  "dependencies": {
    "@vechain/sdk-core": "^2.0.7",
    "@vechain/sdk-network": "^2.0.7",
    "bignumber.js": "^9.1.2",
    "commander": "^14.0.1",
    "fastify": "^5.6.1",
    "globby": "^14.1.0",
    "handlebars": "^4.7.8",
    "pino": "^10.1.0",
    "web3-eth-abi": "^4.4.1",
    "ws": "^8.18.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
