{
  "name": "vechain.webhooks",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted VeChain webhook processor configured with YAML and launched with Docker Compose.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "app:dev": "vite --config apps/yml-generator/vite.config.ts",
    "app:build": "vite build --config apps/yml-generator/vite.config.ts",
    "app:preview": "vite preview --config apps/yml-generator/vite.config.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/yml-generator/tsconfig.json",
    "test": "vitest run --workspace vitest.workspace.ts",
    "validate": "tsx src/cli/index.ts validate",
    "dry-run": "tsx src/cli/index.ts dry-run",
    "print-rules": "tsx src/cli/index.ts print-rules"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@vechain/sdk-core": "^2.0.7",
    "@vechain/sdk-network": "^2.0.7",
    "bignumber.js": "^9.1.2",
    "commander": "^14.0.1",
    "fastify": "^5.6.1",
    "globby": "^14.1.0",
    "handlebars": "^4.7.8",
    "pino": "^10.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "web3-eth-abi": "^4.4.1",
    "ws": "^8.18.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "jsdom": "^29.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.4"
  }
}
